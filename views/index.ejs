<%- include('./partials/header.ejs', {}) %>
<br/><br/>
<section class="clean-block clean-form dark p-5" align="center">

    <img src="<%= data[0].owner.avatar_url %>" class="shadow-lg rounded-pill" id="index-logo"><br/><br/>
    <h1 id="index-text">
        Self taught<br/>
        Full-stack web developer
    </h1>
    <p>Hi, my name is Arda, I am from Turkey and I am a self taught web developer.<br/> I started building a website from the age of 14.</p>
  </section>

  <section class="clean-block clean-form dark p-5">
    <div class="container">
      <div class="row">        
        <h3 id="index-text">Blog:</h3>
              <% for(i=0;i < blog.length; i++){ %>
                <div class="col-sm-3 mb-2">
                  <div class="card bg-dark text-light" >
                      <img src="<%= blog[i].thumbnail %>" class="card-img-top" alt="img">
                      <div class="card-body">
                        <h5 class="card-title"><%= blog[i].title %></h5>
                        <p class="card-text text-truncate"><%= blog[i].content %></p>
                        <a href="/blog/<%= blog[i].id %>" class="btn btn-primary rounded">READ MORE</a>
                      </div>
                    </div>
                  </div>
              <% } %>
  
  </div></div>
  </section>

<section class="clean-block clean-form dark p-5">
    <div class="container">
      <div class="row">
        <h3 id="index-text">GitHub Repository:</h3>
              <% for(i=0; i < data.length; i++){ %>
                <div class="col-sm-3 mb-2">
                  <div class="card bg-dark text-light">
                    <img src="https://png.pngitem.com/pimgs/s/128-1280494_github-github-logo-thumbnail-hd-png-download.png" class="card-img-top" alt="img">
                      <div class="card-body">
                        <h5 class="card-title"><%= data[i].name %></h5>
                        <p class="card-text text-truncate"><%= data[i].language %> / <%= data[i].stargazers_count %> <i class="fas fa-star"></i></p>
                        <a href="<%= data[i].html_url %>" class="btn btn-primary rounded">SEE MORE</a>
                      </div>
                    </div>
                  </div>
              <% } %>
  </div></div>
  </section>

<section class="p-5">
  <div class="container">
    <div class="row">
    <h3 id="index-text">Languages and tools:</h3>
    <br/>
    <div class="row">
    <div class="col-md-2 col-md-push-2 col-xs-12 mb-2"><a id="tech-text"><i class="fab fa-js-square" style="color:#efd81d"></i> Javascript</a></div>
    <div class="col-md-2 col-md-pull-2 col-xs-12"><a id="tech-text"><i class="fab fa-html5" style="color:#de4b25"></i> Html</a></div>
    <div class="col-md-2 col-xs-12"><a id="tech-text"><i class="fab fa-css3-alt" style="color:#146eb1"></i> Css</a></div>
    <div class="col-md-2 col-md-push-2 col-xs-12"><a id="tech-text"><i class="fab fa-node-js" style="color:#74a862"></i> Node.js</a></div>
    <div class="col-md-2 col-md-pull-2 col-xs-12"><a id="tech-text"><i class="fab fa-git-alt" style="color:#e94e31"></i> Git</a></div>
    <div class="col-md-2 col-xs-12"><a id="tech-text"><i class="fas fa-database" style="color:#005d88"></i> MySql</a></div>
    <div class="col-md-2 col-xs-12"><a id="tech-text"><i class="fas fa-cloud" style="color:#479848"></i> MongoDB</a></div>
</div>
</div></div>
</section>

<%- include('./partials/footer.ejs', {}) %>