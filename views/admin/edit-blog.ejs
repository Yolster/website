<%- include('../partials/header.ejs', {}) %>
<section class="p-5">
    <div class="p-5">
        <div class="p-5">
    <h1><i class="fas fa-blog"></i> Edit Blog</h1>
    <br/>
    <form action="/admin/blog/<%= blog[0].id %>" method="POST" class="form">
        <label for="title" style="font-weight: bold;">Title</label>
        <input type="text" id="title" name="title" value="<%= blog[0].title %>" class="form-control border border-dark"/><br/><br/>
        
        <label for="thumbnail" style="font-weight: bold;">Thumbnail</label>
        <input type="text" id="thumbnail" name="thumbnail" value="<%= blog[0].thumbnail %>" class="form-control border border-dark"/><br/><br/>
        
        <label for="content" style="font-weight: bold;">Content</label>
        <textarea id="content" name="content" class="form-control border border-dark"><%= blog[0].content %></textarea><br/>

        <input type="submit" class="btn btn-outline-dark rounded" width="150px" height="50px">
    </form>
<br/><br/><br/><br/><br/><br/>
    <form action="/admin/blogdelete/<%= blog[0].id %>" method="POST" class="form">
        <h4>Dangerous Area</h4>
        <input type="submit" class="btn btn-outline-danger rounded" value="Delete Blog" width="150px" height="50px">
    </form>
</div></div>
</section>

<%- include('../partials/footer.ejs', {}) %>