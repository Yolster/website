<%- include('../partials/header.ejs', {}) %>
<section class="p-5">
    <div class="p-5">
        <div class="p-5">
    <h1><i class="fas fa-blog"></i> New Blog</h1>
    <br/>
    <form action="/admin/blog/new" method="POST" class="form">
        <label for="title" style="font-weight: bold;">Title</label>
        <input type="text" id="title" name="title" class="form-control border border-dark"/><br/><br/>
        
        <label for="thumbnail" style="font-weight: bold;">Thumbnail</label>
        <input type="text" id="thumbnail" name="thumbnail" class="form-control border border-dark"/><br/><br/>
        
        <label for="content" style="font-weight: bold;">Content</label>
        <textarea id="content" name="content" class="form-control border border-dark"></textarea><br/>

        <input type="submit" class="btn btn-outline-dark rounded" width="150px" height="50px">
    </form>
</div></div>
</section>

